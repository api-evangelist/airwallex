{
  "opencollection": "1.0.0",
  "info": {
    "name": "Airwallex Open API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Authentication",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Obtain access token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.airwallex.com/api/v1/authentication/login"
          },
          "docs": "Exchange the client_id and api_key (sent as `x-client-id` and `x-api-key`\nheaders) for a short-lived bearer access token used in subsequent calls.\n"
        }
      ]
    },
    {
      "info": {
        "name": "Payment Intents",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create a payment intent",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.airwallex.com/api/v1/payment_intents/create"
          },
          "docs": "Create a payment intent"
        },
        {
          "info": {
            "name": "Retrieve payment intent",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.airwallex.com/api/v1/payment_intents/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve payment intent"
        },
        {
